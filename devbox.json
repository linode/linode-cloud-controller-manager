{
  "packages": [
    "ctlptl@0.9.3",
    "docker@29.4.3",
    "envsubst@1.4.3",
    "go@1.26.2",
    "golangci-lint@2.12.2",
    "jq@1.8.1",
    "kind@0.31.0",
    "kubectl@1.36.1",
    "kustomize@5.8.1",
    "kyverno-chainsaw@0.2.14",
    "mockgen@1.6.0",
    "yq-go@4.53.2",
