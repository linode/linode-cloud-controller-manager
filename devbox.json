      "e2e-test-ipv6-backends": "make e2e-test-ipv6-backends",
      "e2e-test-bgp": "make e2e-test-bgp",
      "e2e-test-subnet": "make e2e-test-subnet",
      "cleanup-cluster": "make cleanup-cluster"
    }
  },
  "env": {
    "EXP_CLUSTER_RESOURCE_SET": "true",
    "GOTOOLCHAIN": "auto"
  }
}
